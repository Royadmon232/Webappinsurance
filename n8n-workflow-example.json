      "parameters": {
        "jsCode": "// לוגיקה לעיבוד ליד מושלם\nconst data = $input.all();\n\nfor (const item of data) {\n  console.log('🎯 ליד חדש התקבל:', {\n    name: item.json.customer_name,\n    email: item.json.customer_email,\n    phone: item.json.customer_phone,\n    product: item.json.product_type,\n    city: item.json.property_city,\n    time: item.json.formatted_time,\n    value: item.json.lead_value\n  });\n  \n  // כאן אפשר להוסיף:\n  // - שליחה ל-CRM\n  // - שמירה במסד נתונים\n  // - התראות לצוות מכירות\n  // - ניקוד ליד (lead scoring)\n}\n\nreturn $input.all();"
      },
