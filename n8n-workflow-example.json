    {
      "parameters": {
        "jsCode": "// לוגיקה לשמירת נתוני אימות מייל\nconst data = $input.all();\n\nfor (const item of data) {\n  console.log('🔐 קוד אימות נשלח:', {\n    email: item.json.customer_email,\n    code: item.json.verification_code,\n    time: item.json.formatted_time\n  });\n  \n  // כאן אפשר להוסיף לוגיקה לשמירה במסד נתונים\n  // או שליחה לשירותים חיצוניים\n}\n\nreturn $input.all();"
