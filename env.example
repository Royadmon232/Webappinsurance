# Gmail API (OAuth2) — used by /api/lead to email incoming leads.
# Configure these in the Vercel project environment variables.
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=your_gmail_redirect_uri
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Where lead notifications are delivered (defaults to the agency mailbox).
LEAD_TO_EMAIL=yizhaq@admon-ins.co.il
